# Default: Vite proxies /__auth → :7475 and /__driver → :8081 (see vite.config.ts).
# Set VITE_USE_PROXY=false to call backends directly (requires CORS — enabled on Auth & Driver for :5173).

# VITE_USE_PROXY=false
# VITE_AUTH_API_BASE=http://localhost:7475
# VITE_DRIVER_API_BASE=http://localhost:8081
# VITE_BOOKING_API_BASE=http://localhost:8001
# VITE_PAYMENT_API_BASE=http://localhost:8082
