{
	"info": {
		"_postman_id": "urbanlift-api-collection-2026",
		"name": "UrbanLift — Complete API Collection",
		"description": "Complete Postman collection for UrbanLift ride-hailing microservices backend.\n\nIncludes all 27 REST endpoints across 7 microservices.\n\nBase URLs:\n- Direct: Use individual service ports\n- Gateway: http://localhost:8080\n\nStartup Order:\n1. MySQL, Kafka, Redis\n2. Eureka (:8761)\n3. Auth, Driver, Location services\n4. Booking, Payment, Notification, Socket services\n5. API Gateway (:8080)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
