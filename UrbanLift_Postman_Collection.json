	"item": [
		{
			"name": "1. Auth Service",
			"description": "Passenger authentication — signup, signin, validate.\nPort: 7475",
			"item": [
				{
					"name": "1.1 Signup Passenger",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('PASSENGER_ID', jsonData.id);",
									"    pm.test('Passenger created successfully', function () {",
									"        pm.expect(jsonData.id).to.be.a('number');",
									"        pm.expect(jsonData.email).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phoneNumber\": \"+919876543210\",\n    \"password\": \"SecurePass123\",\n    \"address\": \"123 Main St, Delhi\"\n}"
						},
						"url": {
							"raw": "{{AUTH_BASE_URL}}/api/v1/auth/signup/passenger",
							"host": ["{{AUTH_BASE_URL}}"],
							"path": ["api", "v1", "auth", "signup", "passenger"]
						},
						"description": "Register a new passenger account.\n\n**Classes involved:**\n- AuthController.signup()\n- AuthService.signUpPassenger()\n- PassengerRepository.save()\n\n**If fails:**\n- 500 DataIntegrityViolation → duplicate email\n- 500 JPA error → table schema mismatch (ddl-auto: validate)"
					},
					"response": []
				},
				{
					"name": "1.2 Signin Passenger",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.test('Signin successful', function () {",
									"        pm.expect(jsonData.success).to.be.true;",
									"    });",
									"    // Extract JWT from Set-Cookie header",
									"    var cookies = pm.response.headers.get('Set-Cookie');",
									"    if (cookies) {",
									"        var match = cookies.match(/JWT_TOKEN=([^;]+)/);",
									"        if (match) {",
									"            pm.collectionVariables.set('PASSENGER_JWT', match[1]);",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123\"\n}"
						},
						"url": {
							"raw": "{{AUTH_BASE_URL}}/api/v1/auth/signin/passenger",
							"host": ["{{AUTH_BASE_URL}}"],
							"path": ["api", "v1", "auth", "signin", "passenger"]
						},
						"description": "Authenticate passenger and get JWT cookie.\n\n**Classes involved:**\n- AuthController.signin()\n- AuthenticationManager.authenticate()\n- UserDetailsServiceImpl.loadUserByUsername()\n- JwtService.createToken()\n\n**If fails:**\n- 403 → CSRF enabled, check SpringSecurity config\n- 401 UsernameNotFound → email not in DB\n- 401 BadCredentials → wrong password\n\n**Known issue:** Token is created with hardcoded 'Abc@gmail' instead of actual email."
					},
					"response": []
				},
				{
					"name": "1.3 Validate Token",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "JWT_TOKEN={{PASSENGER_JWT}}"
							}
						],
						"url": {
							"raw": "{{AUTH_BASE_URL}}/api/v1/auth/validate",
							"host": ["{{AUTH_BASE_URL}}"],
							"path": ["api", "v1", "auth", "validate"]
						},
						"description": "Validate existing JWT token from cookie.\n\n**Classes involved:**\n- AuthController.validate()\n- JwtService.extractSubject(), isTokenValid()\n\n**If fails:**\n- 401 'No cookies found' → Cookie not sent\n- 401 'Invalid JWT_TOKEN' → Token expired or wrong secret"
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Driver Service",
			"description": "Driver auth, profile, availability, location.\nPort: 8081",
			"item": [
				{
					"name": "2.1 Driver Signup",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('DRIVER_ID', jsonData.id);",
									"    pm.test('Driver created successfully', function () {",
									"        pm.expect(jsonData.id).to.be.a('number');",
									"        pm.expect(jsonData.driverApprovalStatus).to.equal('PENDING');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Rajesh\",\n    \"lastName\": \"Kumar\",\n    \"email\": \"rajesh.driver@example.com\",\n    \"phoneNumber\": \"+919876543211\",\n    \"password\": \"DriverPass123\",\n    \"address\": \"456 Driver Lane, Mumbai\",\n    \"licenseNumber\": \"DL-1234567890\",\n    \"aadharNumber\": \"1234-5678-9012\",\n    \"activeCity\": \"Mumbai\",\n    \"car\": {\n        \"plateNumber\": \"MH-01-AB-1234\",\n        \"colorName\": \"White\",\n        \"brand\": \"Maruti\",\n        \"model\": \"Swift Dzire\",\n        \"carType\": \"SEDAN\"\n    }\n}"
						},
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/auth/signup",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "auth", "signup"]
						},
						"description": "Register a new driver with vehicle details.\nDriver starts as PENDING — must be APPROVED in DB before signin.\n\nValid carType: XL, SEDAN, HATCHBACK, COMPACT_SUV, SUV\n\n**Classes involved:**\n- DriverAuthController.signUp()\n- DriverAuthService.signUp(), toDto()\n- DriverRepository, CarRepository, ColorRepository\n\n**If fails:**\n- 500 DataIntegrity → duplicate email/license/aadhar\n- 500 IllegalArgument → invalid carType\n\n**After signup, approve in DB:**\nUPDATE driver SET driver_approval_status = 'APPROVED' WHERE email = 'rajesh.driver@example.com';"
					},
					"response": []
				},
				{
					"name": "2.2 Driver Signin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.test('Driver signin successful', function () {",
									"        pm.expect(jsonData.success).to.be.true;",
									"    });",
									"    var cookies = pm.response.headers.get('Set-Cookie');",
									"    if (cookies) {",
									"        var match = cookies.match(/DRIVER_JWT=([^;]+)/);",
									"        if (match) {",
									"            pm.collectionVariables.set('DRIVER_JWT', match[1]);",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"rajesh.driver@example.com\",\n    \"password\": \"DriverPass123\"\n}"
						},
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/auth/signin",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "auth", "signin"]
						},
						"description": "Authenticate driver. MUST be APPROVED first.\n\n**Pre-condition SQL:**\nUPDATE driver SET driver_approval_status = 'APPROVED' WHERE email = 'rajesh.driver@example.com';\n\n**Classes involved:**\n- DriverAuthController.signIn()\n- DriverRepository.findByEmail()\n- JwtAuthService.createToken()\n- PasswordEncoder.matches()\n\n**If fails:**\n- 401 success:false → Driver not APPROVED, wrong password, or email not found"
					},
					"response": []
				},
				{
					"name": "2.3 Validate Driver Token",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "DRIVER_JWT={{DRIVER_JWT}}"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{DRIVER_JWT}}",
								"disabled": true
							}
						],
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/auth/validate",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "auth", "validate"]
						},
						"description": "Validate driver JWT. Accepts cookie or Bearer token.\n\n**Classes involved:**\n- DriverAuthController.validate()\n- JwtAuthService.extractSubject(), isTokenValid()"
					},
					"response": []
				},
				{
					"name": "2.4 Get Driver Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Cookie",
								"value": "DRIVER_JWT={{DRIVER_JWT}}"
							}
						],
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/profile",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "profile"]
						},
						"description": "Get authenticated driver's profile. Requires JWT.\n\n**Classes involved:**\n- DriverProfileController.getProfile()\n- DriverAuthService.toDto()\n- JwtAuthFilter.doFilterInternal()\n- DriverRepository.findByEmail()\n\n**If fails:**\n- 401 → Missing/invalid JWT\n- 500 IllegalArgument → Token email not in DB\n- 500 LazyInit → Check enable_lazy_load_no_trans in config"
					},
					"response": []
				},
				{
					"name": "2.5 Set Driver Availability",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "DRIVER_JWT={{DRIVER_JWT}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"available\": true\n}"
						},
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/availability?lat=19.0760&lng=72.8777",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "availability"],
							"query": [
								{
									"key": "lat",
									"value": "19.0760"
								},
								{
									"key": "lng",
									"value": "72.8777"
								}
							]
						},
						"description": "Set driver availability. Optional lat/lng saves location.\n\n**Classes involved:**\n- DriverAvailabilityController.setAvailability()\n- DriverAvailabilityService.setAvailability()\n- DriverLocationService.updateLocation()\n- LocationServiceApi (Retrofit) → POST /api/location/drivers\n\n**If fails:**\n- 500 RuntimeException → Location Service unreachable (port 7777)\n- 401 → Missing auth token"
					},
					"response": []
				},
				{
					"name": "2.6 Update Driver Location",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Cookie",
								"value": "DRIVER_JWT={{DRIVER_JWT}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"latitude\": 19.0760,\n    \"longitude\": 72.8777\n}"
						},
						"url": {
							"raw": "{{DRIVER_BASE_URL}}/api/v1/driver/location",
							"host": ["{{DRIVER_BASE_URL}}"],
							"path": ["api", "v1", "driver", "location"]
						},
						"description": "Update driver's current GPS location.\n\n**Classes involved:**\n- DriverLocationController.updateLocation()\n- DriverLocationService.updateLocation()\n- LocationServiceApi (Retrofit) → POST /api/location/drivers\n\n**If fails:**\n- 500 RuntimeException → Location Service unreachable\n- 500 ConnectException → Check RetrofitConfig base URL"
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Booking Service",
			"description": "Ride booking lifecycle — create, update, cancel, query.\nPort: 8001",
			"item": [
				{
					"name": "3.1 Create Booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('BOOKING_ID', jsonData.bookingId);",
									"    pm.test('Booking created', function () {",
									"        pm.expect(jsonData.bookingId).to.be.a('number');",
									"        pm.expect(jsonData.bookingStatus).to.equal('ASSIGNING_DRIVER');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"passengerId\": {{PASSENGER_ID}},\n    \"startLocation\": {\n        \"latitude\": 19.0760,\n        \"longitude\": 72.8777\n    },\n    \"endLocation\": {\n        \"latitude\": 19.1136,\n        \"longitude\": 72.8697\n    }\n}"
						},
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking"]
						},
						"description": "Create a new ride booking. Async flow: finds nearby drivers → sends ride request to Socket Service.\n\n**Classes involved:**\n- BookingController.createBooking()\n- BookingServiceImpl.createBooking()\n- BookingServiceImpl.processNearbyDrivers() [async Retrofit]\n- BookingServiceImpl.raiseRideRequestAsync() [async Retrofit]\n- LocationServiceApi (Retrofit) → POST /api/location/nearby/drivers\n- UberSocketApi (Retrofit) → POST /api/socket/newride\n- PassengerRepository.findById()\n- BookingRepository.save()\n\n**If fails:**\n- 500 IllegalArgument → Passenger not found\n- 500 RetrofitError → Location/Socket service unreachable\n- 201 but no driver → No drivers in Redis"
					},
					"response": []
				},
				{
					"name": "3.2 Get Booking by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/{{BOOKING_ID}}",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "{{BOOKING_ID}}"]
						},
						"description": "Get booking details by ID.\n\n**Classes involved:**\n- BookingController.getBooking()\n- BookingServiceImpl.getBookingById(), toDetailDto()\n- BookingRepository.findById()\n\n**If fails:**\n- 500 IllegalArgument → Booking not found"
					},
					"response": []
				},
				{
					"name": "3.3 Update Booking (Assign Driver)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"SCHEDULED\",\n    \"driverId\": {{DRIVER_ID}}\n}"
						},
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/{{BOOKING_ID}}",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "{{BOOKING_ID}}"]
						},
						"description": "Update booking — assign driver and/or change status.\n\nValid status: SCHEDULED, CANCELLED, CAB_ARRIVED, ASSIGNING_DRIVER, IN_RIDE, COMPLETED\n\n**Classes involved:**\n- BookingController.updateBooking()\n- BookingServiceImpl.updateBooking()\n- BookingRepository.updateBookingStatusAndDriverById()\n- DriverRepository.findById()\n\n**If fails:**\n- 500 IllegalArgument → Booking or driver not found\n- 500 IllegalArgument → Invalid status enum"
					},
					"response": []
				},
				{
					"name": "3.4 Get Bookings by Passenger",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/passenger/{{PASSENGER_ID}}",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "passenger", "{{PASSENGER_ID}}"]
						},
						"description": "Get all bookings for a passenger.\n\n**Classes involved:**\n- BookingController.getBookingsByPassenger()\n- BookingServiceImpl.getBookingsByPassengerId()\n- BookingRepository.findByPassengerId()"
					},
					"response": []
				},
				{
					"name": "3.5 Get Bookings by Driver",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/driver/{{DRIVER_ID}}",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "driver", "{{DRIVER_ID}}"]
						},
						"description": "Get all bookings for a driver.\n\n**Classes involved:**\n- BookingController.getBookingsByDriver()\n- BookingServiceImpl.getBookingsByDriverId()\n- BookingRepository.findByDriverId()"
					},
					"response": []
				},
				{
					"name": "3.6 Update Booking Status",
					"request": {
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/{{BOOKING_ID}}/status?status=CAB_ARRIVED",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "{{BOOKING_ID}}", "status"],
							"query": [
								{
									"key": "status",
									"value": "CAB_ARRIVED",
									"description": "Valid: SCHEDULED, CANCELLED, CAB_ARRIVED, ASSIGNING_DRIVER, IN_RIDE, COMPLETED"
								}
							]
						},
						"description": "Update booking status. Triggers Kafka notifications.\n\nSide effects:\n- CAB_ARRIVED → notification event\n- IN_RIDE → notification event\n- COMPLETED → notification + booking-completed-topic (Payment Service consumes)\n- CANCELLED → notification event\n\n**Classes involved:**\n- BookingController.updateStatus()\n- BookingServiceImpl.updateBookingStatus()\n- BookingServiceImpl.sendNotificationForStatusChange() [private]\n- KafkaProducerService.sendBookingCompletedEvent()\n- KafkaProducerService.sendNotificationEvent()\n- BookingRepository.updateBookingStatusById()\n\n**If fails:**\n- 500 IllegalArgument → Invalid status string\n- 500 KafkaException → Kafka unreachable"
					},
					"response": []
				},
				{
					"name": "3.7 Cancel Booking",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{BOOKING_BASE_URL}}/api/v1/booking/{{BOOKING_ID}}/cancel",
							"host": ["{{BOOKING_BASE_URL}}"],
							"path": ["api", "v1", "booking", "{{BOOKING_ID}}", "cancel"]
						},
						"description": "Cancel a booking (sets status to CANCELLED).\n\n**Classes involved:**\n- BookingController.cancelBooking()\n- BookingServiceImpl.cancelBooking() → updateBookingStatus()"
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Location Service",
			"description": "Driver geolocation — save and query nearby drivers via Redis GEO.\nPort: 7777",
			"item": [
				{
					"name": "4.1 Save Driver Location",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
